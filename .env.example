# Copy this to .env for local development (never commit .env)
# In Vercel, set these in Project Settings → Environment Variables

BREVO_API_KEY=xkeysib-...

PO_SENDER_NAME=Innago
PO_SENDER_EMAIL=newsletter@innago.com

REI_SENDER_NAME=REI Grove
REI_SENDER_EMAIL=newsletter@reig rove.com

# Optional — only needed if using REI Grove newsletter scraping
REI_GROVE_BLOG_URL=https://
REI_GROVE_WEBINAR_URL=https://

# Optional — basic password to protect the app (recommended for team use)
APP_PASSWORD=
